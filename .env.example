# Django Configuration
# ------------------------------------------------------------------------------
# WARNING: Do not commit the .env file to version control.
# This file contains sensitive information and should be kept private.
# For production, use a secure way to manage these variables.

# SECURITY: This should be a long, random string.
# Generate one here: https://djecrety.ir/
SECRET_KEY=your-super-secret-key-goes-here

# CORE: Set to 'False' in production.
DEBUG=True

# NETWORKING: Comma-separated list of hosts. e.g., 'localhost,127.0.0.1,.yourdomain.com'
ALLOWED_HOSTS=127.0.0.1,localhost

# DATABASE: URL format for database configuration.
# Examples:
# PostgreSQL: postgres://user:password@host:port/dbname
# MySQL: mysql://user:password@host:port/dbname
# SQLite: sqlite:///path/to/your/db.sqlite3 (leave empty to use default)
DATABASE_URL=

# EMAIL: Configuration for sending emails.
# For development, you can use 'django.core.mail.backends.console.EmailBackend'
# which prints emails to the console.
# ------------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password

# THIRD-PARTY SERVICES
# ------------------------------------------------------------------------------
# Stripe API keys for payment processing.
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Google Gemini API Key for AI features.
GEMINI_API_KEY=your-gemini-api-key

# Unsplash API Key for images.
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
